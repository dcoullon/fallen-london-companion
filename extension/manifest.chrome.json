{
  "manifest_version": 3,
  "name": "Fallen London Companion",
  "version": "0.3",
  "description": "Quality of life improvements for Fallen London",
  "minimum_chrome_version": "109",
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.fallenlondon.com/*"],
      "js": ["prices.js", "content.js"],
      "css": ["diagnostic.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "permissions": ["storage"],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://www.fallenlondon.com/*"]
    }
  ]
}
