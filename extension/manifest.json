{
  "manifest_version": 3,
  "name": "Fallen London Companion",
  "version": "0.3",
  "description": "Quality of life improvements for Fallen London",
  "browser_specific_settings": {
    "gecko": {
      "id": "fallen-london-companion@ext",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["*://www.fallenlondon.com/*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": ["*://www.fallenlondon.com/*"]
    }
  ]
}
